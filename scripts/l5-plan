#!/usr/bin/env python3
"""Plan a story interactively with the planner agent.

Usage: l5-plan "<story request>"
Starts an interactive Claude Code session carrying the planner prompt.
The planner interviews you, iterates on the plan, and writes the approved
story artifact to .harness/stories/.
"""
import os
import sys
from pathlib import Path

HARNESS_ROOT = Path(__file__).resolve().parents[1]


def main() -> None:
    if len(sys.argv) < 2:
        sys.exit(__doc__.strip())
    request = " ".join(sys.argv[1:])
    planner_prompt = (HARNESS_ROOT / "prompts" / "planner.md").read_text(encoding="utf-8")
    os.execvp(
        "claude",
        [
            "claude",
            "--permission-mode",
            "acceptEdits",
            "--append-system-prompt",
            planner_prompt,
            f"Story request: {request}",
        ],
    )


if __name__ == "__main__":
    main()
