#!/usr/bin/env python3
"""Launch the interactive assist agent: a copilot for the harness itself.

Usage: l5-assist ["<question>"]
"""
import os
import sys
from pathlib import Path

HARNESS_ROOT = Path(__file__).resolve().parents[1]


def main() -> None:
    assist_prompt = (HARNESS_ROOT / "prompts" / "assist.md").read_text(encoding="utf-8")
    args = [
        "claude",
        "--permission-mode",
        "acceptEdits",
        "--append-system-prompt",
        assist_prompt,
    ]
    if len(sys.argv) > 1:
        args.append(" ".join(sys.argv[1:]))
    os.execvp("claude", args)


if __name__ == "__main__":
    main()
